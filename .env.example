# =============================================================
# Granderson Destinations — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
#
# FEATURE FLAG: Any integration whose key is missing falls back
# to a "stub mode" that returns realistic mock data so the app
# remains fully usable while keys are provisioned.
# =============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://granderson-destinations.vercel.app
NEXT_PUBLIC_DEMO_MODE=false

# --- Supabase (auth + DB) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (booking deposits) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Anthropic Claude (concierge, caption gen, expense flagging) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Perplexity Sonar (city council + entitlement intel, hotspot refresh) ---
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# --- PriceLabs (dynamic pricing backend) ---
PRICELABS_API_KEY=
PRICELABS_BASE_URL=https://api.pricelabs.co/v1

# --- AirDNA MarketMinder (comparable property benchmarking) ---
AIRDNA_API_KEY=
AIRDNA_BASE_URL=https://api.airdna.co/v1
AIRDNA_CLIENT_ID=

# --- Google Maps + Places (neighborhood, distance, hotspot photos) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- Meta Graph (Instagram Business posting + insights) ---
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ID=
META_LONG_LIVED_TOKEN=

# --- ClickUp (maintenance task store) ---
# Personal token from https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=
# The Granderson Destinations space — read from URL or via API
CLICKUP_SPACE_ID=
# Per-property maintenance list ids (create folders → "Maintenance" list per property)
CLICKUP_LIST_PALM_SPRINGS=
CLICKUP_LIST_SAN_MIGUEL=
# Fallback list if a property-specific one isn't set
CLICKUP_DEFAULT_LIST_ID=

# --- Twilio (vendor SMS for maintenance pipeline) ---
# https://console.twilio.com → Account → API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # E.164 e.g. +15551234567

# --- Gmail SMTP (vendor dispatch — primary while Twilio 10DLC pending) ---
# Requires 2-Step Verification, then an App Password from
# https://myaccount.google.com/apppasswords (Mail > Other > "Granderson Destinations")
GMAIL_USER=                       # full Gmail address, e.g. you@gmail.com
GMAIL_APP_PASSWORD=               # 16-char App Password (spaces ok)
# When true (default), email is the primary channel for vendor dispatch.
# Flip to "false" after Twilio A2P 10DLC is approved + assigned to the number.
EMAIL_FALLBACK_PRIMARY=true

# --- Owner notifications (for new tickets) ---
OWNER_NOTIFY_PHONE=               # E.164, optional — SMS to you (10DLC required)
OWNER_NOTIFY_EMAIL=               # email, optional — BCC on every vendor dispatch

# --- Owner admin gate for /maintenance/admin ---
# Long random string (>=32 chars). First visit: append ?key=<value> to URL
# to set the auth cookie; subsequent visits authenticate via cookie for 30d.
OWNER_ADMIN_TOKEN=

# --- Cron / scheduled tasks (intel refresh, pricing sync, IG cadence) ---
CRON_SECRET=
